# Copy this file to .env and fill in real values before deploying.
# .env is gitignored — real secrets never get committed to source control.

PORT=4000

# Required in production (server refuses to start without it there).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Your real frontend origin(s), comma-separated. Defaults to
# http://localhost:5173 if unset.
CORS_ORIGIN=http://localhost:5173

# Primary admin account (School Head). If ADMIN_PASSWORD is left blank, the
# server generates a random one-time password and logs it once on startup —
# set a real value here for any real deployment.
ADMIN_EMAIL=jinodocena11@gmail.com
ADMIN_PASSWORD=

# Master admin account (username-style login, no @ required). Same
# random-password-if-blank behavior as above.
MASTER_ADMIN_USERNAME=biskotso
MASTER_ADMIN_PASSWORD=

# Optional: point at a hosted Turso database instead of the local SQLite
# file. Required for production — without it, data does not survive a
# Render redeploy. Leave both blank for local dev (uses server/data.db).
# See DEPLOY.md for how to create one.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Email (Gmail SMTP via Nodemailer) — sends classroom-invite "Join" links
# and new-assignment notifications. Leave blank to disable: the app still
# works, but those emails are skipped (logged as a warning instead).
# Setup: myaccount.google.com/security -> turn on 2-Step Verification ->
# search "App passwords" -> generate one for "Mail" -> paste it below
# (NOT your normal Gmail password).
EMAIL_USER=
EMAIL_APP_PASSWORD=
# Optional — defaults to EMAIL_USER if unset.
EMAIL_FROM=

# Public URL of the deployed frontend — used to build the invite/join links
# inside emails. Defaults to http://localhost:5173 for local dev.
CLIENT_URL=http://localhost:5173
