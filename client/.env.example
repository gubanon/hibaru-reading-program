# Copy to .env.production (or set in your host's dashboard, e.g. Vercel
# project settings → Environment Variables) before deploying.
#
# Leave unset for local dev — the Vite dev server proxies relative /api/*
# calls to the backend (see vite.config.js), so no value is needed there.
#
# In production the frontend and backend are on different domains, so this
# must point at your deployed backend's full origin, no trailing slash:
VITE_API_URL=https://hibaru-reading-api.fly.dev
